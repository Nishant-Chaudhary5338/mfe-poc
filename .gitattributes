# Normalize line endings to LF in the repo; checkout as-is on all platforms
* text=auto eol=lf

# Force LF for shell scripts and source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.sh   text eol=lf

# Binary files — do not touch line endings
*.png  binary
*.jpg  binary
*.ico  binary
*.woff binary
*.woff2 binary
